DataDirectory /app/data/tor
SocksTimeout 15
UseBridges 1

# Tor 0.4.8+ enables conflux by default for HS-client traffic. Conflux requires
# two link-disjoint paths, which means ≥3 distinct guards. With exactly two
# bridges, conflux can never form the second path → circuits die with
# "Unlinked conflux circuit" / "Failed to find node for hop #1" and the proxy
# never carries traffic. Since this image's only target is the Cloudflare DNS
# .onion, every DoT query rides a HS circuit, so conflux is fatal here.
# Disable it to make 2-bridge configs work as designed.
ConfluxEnabled 0

# Match the bridge count so Tor doesn't keep one primary-guard slot
# permanently empty and log "missing descriptors for 1/3 of our primary entry
# guards" forever. Default NumPrimaryGuards is 3.
NumPrimaryGuards 2

# SOCKS proxy: explicit loopback bind; socat connects here for SOCKS4A routing.
SocksPort 127.0.0.1:9050
# No ControlPort — no authenticated management channel exposed.

ClientTransportPlugin obfs4 exec /usr/bin/lyrebird
